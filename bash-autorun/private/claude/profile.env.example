# description: 示例配置（复制此文件并重命名以创建新 profile）
#
# 文件命名规则：<profile名称>.env
# 例如：mycompany.env -> claude --env mycompany
#
# 支持的环境变量：
#
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/
#   API 代理地址，留空则使用官方默认地址
#
# ANTHROPIC_AUTH_TOKEN=sk-your-token-here
#   API 认证 Token
#
# API_TIMEOUT_MS=3000000
#   请求超时时间（毫秒），适用于响应较慢的代理
#
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
#   禁用非必要的网络请求（推荐在第三方代理下开启）
#
# ANTHROPIC_DEFAULT_HAIKU_MODEL=model-name
#   覆盖 Haiku 模型名称（适用于兼容 API 的第三方模型）
#
# ANTHROPIC_DEFAULT_SONNET_MODEL=model-name
#   覆盖 Sonnet 模型名称
#
# ANTHROPIC_DEFAULT_OPUS_MODEL=model-name
#   覆盖 Opus 模型名称
#
# 使用示例：
#   claude --env example        # 指定 profile 启动
#   claude                      # 交互式选择 profile
